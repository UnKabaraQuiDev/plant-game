<project xmlns="http://maven.apache.org/POM/4.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>

	<parent>
		<groupId>lu.kbra</groupId>
		<artifactId>plant-game</artifactId>
		<version>${revision}</version>
		<relativePath>../pom.xml</relativePath>
	</parent>

	<artifactId>plant-game-core</artifactId>

	<name>Plant Game (Core)</name>
	<description>The core of a game about plants</description>

	<properties>
		<package.base>lu.kbra.plant_game.base</package.base>
		<package.registries>${package.base}.reg</package.registries>
		<lwjgl.natives>natives-${os.detected.classifier}</lwjgl.natives>
	</properties>

	<dependencies>
		<dependency>
			<groupId>lu.kbra</groupId>
			<artifactId>gameengine</artifactId>
		</dependency>
		<dependency>
			<groupId>junit</groupId>
			<artifactId>junit</artifactId>
		</dependency>
		<dependency>
			<groupId>com.squareup</groupId>
			<artifactId>javapoet</artifactId>
		</dependency>
		<dependency>
			<groupId>org.reflections</groupId>
			<artifactId>reflections</artifactId>
		</dependency>
		<dependency>
			<groupId>lu.kbra</groupId>
			<artifactId>plant-game-autogen</artifactId>
			<version>0.1</version>
		</dependency>
	</dependencies>

	<build>
		<extensions>
			<extension>
				<groupId>kr.motd.maven</groupId>
				<artifactId>os-maven-plugin</artifactId>
				<version>1.7.1</version>
			</extension>
			<extension>
				<groupId>org.apache.maven.wagon</groupId>
				<artifactId>wagon-http</artifactId>
				<version>3.5.3</version>
			</extension>
		</extensions>

		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.11.0</version>
				<executions>
					<execution>
						<id>compile-generator</id>
						<phase>generate-sources</phase>
						<goals>
							<goal>compile</goal>
						</goals>
						<configuration>
							<includes>
								<include>**/*GenMain.java</include>
							</includes>
							<outputDirectory>
								${project.build.directory}/generated-classes</outputDirectory>
						</configuration>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>lu.kbra</groupId>
				<artifactId>plant-game-autogen</artifactId>
				<version>${project.version}</version>
				<executions>
					<execution>
						<phase>process-classes</phase>
						<goals>
							<goal>gen-go-registry</goal>
							<goal>gen-ui-registry</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<executions>

					<!-- normal compile -->
					<execution>
						<id>default-compile</id>
						<phase>compile</phase>
						<goals>
							<goal>compile</goal>
						</goals>
					</execution>

					<!-- second compile pass -->
					<execution>
						<id>recompile-generated</id>
						<phase>prepare-package</phase>
						<goals>
							<goal>compile</goal>
						</goals>
					</execution>

				</executions>
			</plugin>
			<plugin>
				<groupId>org.codehaus.mojo</groupId>
				<artifactId>exec-maven-plugin</artifactId>
				<version>3.5.0</version>
				<executions>
					<execution>
						<goals>
							<goal>java</goal>
						</goals>
					</execution>
				</executions>
				<configuration>
					<mainClass>lu.kbra.plant_game.PGMain</mainClass>
				</configuration>
			</plugin>

			<plugin>
				<groupId>io.github.fvarrui</groupId>
				<artifactId>javapackager</artifactId>
				<version>1.7.6</version>

				<executions>
					<execution>
						<phase>package</phase>
						<goals>
							<goal>package</goal>
						</goals>
						<configuration>
							<mainClass>lu.kbra.plant_game.PGMain</mainClass>
							<bundleJre>true</bundleJre>
							<bundleJre>true</bundleJre>
							<customizedJre>true</customizedJre>
							<modules>
								<module>java.base</module>
								<module>java.desktop</module>
								<module>java.logging</module>
								<module>jdk.unsupported</module>
							</modules>
							<name>Satisplantory</name>
							<vendor>lu.kbra</vendor>
							<version>${project.version}</version>
							<input>${project.build.directory}</input>
							<mainJar>${project.build.finalName}.jar</mainJar>
							<output>${project.build.directory}/dist</output>
						</configuration>
					</execution>
				</executions>

			</plugin>
		</plugins>
	</build>

	<profiles>
		<profile>
			<id>windows</id>
			<activation>
				<os>
					<family>windows</family>
				</os>
			</activation>
			<properties>
				<lwjgl.natives>natives-windows</lwjgl.natives>
			</properties>

			<build>
				<plugins>
					<plugin>
						<groupId>io.github.fvarrui</groupId>
						<artifactId>javapackager</artifactId>
						<configuration>
							<platform>windows</platform>
							<winConfig>
								<winConsole>false</winConsole>
								<winMenu>true</winMenu>
								<winShortcut>true</winShortcut>
							</winConfig>
						</configuration>
					</plugin>
				</plugins>
			</build>
		</profile>

		<profile>
			<id>mac</id>
			<activation>
				<os>
					<family>mac</family>
				</os>
			</activation>
			<properties>
				<lwjgl.natives>natives-macos</lwjgl.natives>
			</properties>

			<build>
				<plugins>
					<plugin>
						<groupId>io.github.fvarrui</groupId>
						<artifactId>javapackager</artifactId>
						<configuration>
							<platform>mac</platform>
							<macConfig>
								<macAppStore>false</macAppStore>
							</macConfig>
						</configuration>
					</plugin>
				</plugins>
			</build>
		</profile>

		<profile>
			<id>linux</id>
			<activation>
				<os>
					<family>unix</family>
				</os>
			</activation>
			<properties>
				<lwjgl.natives>natives-linux</lwjgl.natives>
			</properties>

			<build>
				<plugins>
					<plugin>
						<groupId>io.github.fvarrui</groupId>
						<artifactId>javapackager</artifactId>
						<configuration>
							<platform>linux</platform>
							<linuxConfig>
								<generateDeb>true</generateDeb>
								<generateRpm>false</generateRpm>
								<generateAppImage>false</generateAppImage>
							</linuxConfig>
						</configuration>
					</plugin>
				</plugins>
			</build>
		</profile>
	</profiles>

</project>